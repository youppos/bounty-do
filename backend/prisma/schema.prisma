datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String?
  level     Int      @default(1)
  coins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id           String    @id
  title        String
  description  String?
  isCompleted  Boolean   @default(false)
  hasAlarm     Boolean   @default(false)
  hasReminder  Boolean   @default(false)
  coinReward   Int       @default(0)
  levelIndex   Int       @default(1)
  deadline     DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
